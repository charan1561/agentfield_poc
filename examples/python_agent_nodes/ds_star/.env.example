# AgentField connection
AGENTFIELD_SERVER=http://localhost:8080

# Azure OpenAI (shared by both AgentField and DS_star)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# DS_star working directory (data files go in $DS_STAR_WORKDIR/data/)
DS_STAR_WORKDIR=/tmp/ds_star

# LLM model for AgentField AIConfig (uses LiteLLM model spec)
AI_MODEL=azure/gpt-5-chat
